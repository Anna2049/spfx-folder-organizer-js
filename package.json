{
  "name": "spfx-folder-organizer-js",
  "version": "1.0.0",
  "private": true,
  "main": "lib/index.js",
  "scripts": {
    "postinstall": "node post-install-patches.js",
    "build": "node --openssl-legacy-provider node_modules/gulp/bin/gulp.js bundle",
    "clean": "node node_modules/gulp/bin/gulp.js clean",
    "test": "node node_modules/gulp/bin/gulp.js test",
    "bundle": "node --openssl-legacy-provider node_modules/gulp/bin/gulp.js bundle --ship",
    "package": "node --openssl-legacy-provider node_modules/gulp/bin/gulp.js package-solution --ship",
    "ship": "node --openssl-legacy-provider node_modules/gulp/bin/gulp.js bundle --ship && node --openssl-legacy-provider node_modules/gulp/bin/gulp.js package-solution --ship",
    "serve": "node --openssl-legacy-provider node_modules/gulp/bin/gulp.js serve"
  },
  "dependencies": {
    "@fluentui/react": "8.48.0",
    "@microsoft/sp-component-base": "1.13.0",
    "@microsoft/sp-core-library": "1.13.0",
    "@microsoft/sp-http": "1.13.0",
    "@microsoft/sp-lodash-subset": "1.13.0",
    "@microsoft/sp-property-pane": "1.13.0",
    "@microsoft/sp-webpart-base": "1.13.0",
    "react": "16.13.1",
    "react-dom": "16.13.1",
    "tslib": "2.3.1"
  },
  "devDependencies": {
    "@microsoft/sp-build-web": "1.12.1",
    "@microsoft/sp-module-interfaces": "1.13.0",
    "@types/react": "16.9.0",
    "@types/react-dom": "16.9.0",
    "@types/webpack-env": "1.15.2",
    "ajv": "6.12.5",
    "dotenv": "16.4.7",
    "gulp": "4.0.2",
    "sass": "^1.32.13",
    "typescript": "4.5.5"
  }
}
